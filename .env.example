# Copy to .env.local and fill in values — NEVER commit .env.local
# See docs/security.md for where each secret lives (Vercel vs Supabase vs GitHub)

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://laqnnzavwbojntfiqmxj.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Site (see also src/lib/site.ts)
NEXT_PUBLIC_SITE_URL=https://protosweb.eu

# Analytics — GA4 (consent-gated)
NEXT_PUBLIC_GA_ID=G-HR9HK4SR7Q

# Admin panel (/admin) — Vercel only
ADMIN_SECRET=

# Agent memory (/admin/memory) — optional if Protos-Agent repo is private
# GITHUB_TOKEN=
# AGENT_MEMORY_REPO=ProtosEschatos/Protos-Agent
# AGENT_MEMORY_BRANCH=main
# AGENT_MEMORY_LOCAL_PATH=

# Live service status on /admin — all optional
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ZONE_ID=
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG_SLUG=
# SENTRY_PROJECT_SLUG=
# VERCEL_TOKEN=
# VERCEL_PROJECT_ID=
# VERCEL_TEAM_ID=

# AI assistant (/admin/ai) — Vercel only, never NEXT_PUBLIC_
# DEEPSEEK_API_KEY=
# GEMINI_API_KEY=

# Email — Supabase Edge secrets (see docs/email-setup.md)
# RESEND_API_KEY=
# BREVO_API_KEY=
# RESEND_FROM_EMAIL=dario.admin@protosweb.eu
# CONTACT_EMAIL=dario.admin@protosweb.eu

# Zoho IMAP — admin inbox (/admin/inbox), Vercel only
# ZOHO_IMAP_USER=dario.admin@protosweb.eu
# ZOHO_IMAP_PASSWORD=
# ZOHO_IMAP_HOST=imappro.zoho.eu
# ZOHO_IMAP_PORT=993

# Martina Zoho IMAP — when martina.admin@protosweb.eu is live
# MARTINA_IMAP_USER=martina.admin@protosweb.eu
# MARTINA_IMAP_PASSWORD=
# MARTINA_IMAP_HOST=imappro.zoho.eu
# MARTINA_IMAP_PORT=993

# Cron — protects /api/cron/* (GitHub Actions admin-inbox-sync)
# CRON_SECRET=

# Stripe — Supabase Edge secrets only (see docs/stripe-donations.md)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
