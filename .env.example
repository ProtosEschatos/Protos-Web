# Protos-Web — popis SVIH env varijabli (struktura = .env.local)
# Agent: vrijednosti su u .env.local na disku — pročitaj ga prije rada.
# Placement: docs/security.md

# --- Supabase (Vercel + GitHub CI + .env.local) ---
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=

# --- Site (Vercel: NEXT_PUBLIC_SITE_URL; Edge: SITE_URL na Supabase) ---
NEXT_PUBLIC_SITE_URL=
SITE_URL=

# --- Analytics (Vercel) ---
NEXT_PUBLIC_GA_ID=
GA_ID=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
GOOGLE_SITE_VERIFICATION=

# --- Admin (Vercel) ---
ADMIN_SECRET=
CRON_SECRET=

# --- Agent memory (Vercel) ---
AGENT_MEMORY_REPO=
AGENT_MEMORY_BRANCH=
GITHUB_TOKEN=

# --- Sentry (Vercel) ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG_SLUG=
SENTRY_PROJECT_SLUG=

# --- Cloudflare (Vercel, admin status) ---
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ACCOUNT_ID=

# --- Vercel (admin status kartica) ---
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=

# --- AI (Vercel, /admin/ai) ---
DEEPSEEK_API_KEY=
GEMINI_API_KEY=

# --- Email (Supabase Edge secrets — NE na Vercel; u .env.local za referencu) ---
RESEND_API_KEY=
BREVO_API_KEY=
RESEND_FROM_EMAIL=
CONTACT_EMAIL=

# --- Zoho IMAP (Vercel — jedini mailbox u kodu) ---
ZOHO_IMAP_USER=
ZOHO_IMAP_PASSWORD=
ZOHO_IMAP_HOST=
ZOHO_IMAP_PORT=

# --- Stripe (Supabase Edge — NE na Vercel) ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- GitHub Actions only ---
SUPABASE_ACCESS_TOKEN=
KEEP_ALIVE_SECRET=
