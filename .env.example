# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://laqnnzavwbojntfiqmxj.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Site (see also src/lib/site.ts — single source of truth)
NEXT_PUBLIC_SITE_URL=https://protosweb.eu

# Analytics — GA4 (consent-gated; loads only after cookie opt-in)
# Defaults to G-BGR7VHFCB2 in src/lib/config/site.ts. Override here only if you need a different property.
# NEXT_PUBLIC_GA_ID=G-BGR7VHFCB2

# Plausible analytics (runs alongside GA when both are set; consent-gated)
# Defaults to protosweb.eu in src/lib/config/site.ts. Override here only if the tracked domain changes.
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=protosweb.eu

# Google Search Console — HTML meta verification (defaults to code value in
# src/lib/config/site.ts; set here only to override without redeploying code)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Google Business Profile (Maps) — public share link for the verified listing
# Defaults to https://share.google/WMPSacg3oKW1Gy8W8 in src/lib/config/site.ts. Override here if it changes.
# NEXT_PUBLIC_GOOGLE_BUSINESS_URL=

# Private admin panel (/admin) — set a strong password; only you see the nav link after login
ADMIN_SECRET=

# Agent memory (/admin/memory) — reads Protos-Agent repo (private → needs GITHUB_TOKEN on Vercel)
# AGENT_MEMORY_REPO=ProtosEschatos/Protos-Agent
# AGENT_MEMORY_BRANCH=main
# GITHUB_TOKEN=
# AGENT_MEMORY_LOCAL_PATH=

# Error monitoring (optional) — /admin shows this as configured once set
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_DSN=

# Live service status on /admin ("Živi status servisa") — all optional,
# each card shows "Nije podešeno" until its variable(s) are set.
# Cloudflare: dash.cloudflare.com → My Profile → API Tokens → create a
# read-only token scoped to Zone → Zone → Read (do NOT reuse a DNS-edit token)
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ZONE_ID=
# Sentry: sentry.io → Settings → Auth Tokens (needs project:read scope)
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG_SLUG=
# SENTRY_PROJECT_SLUG=
# Vercel: vercel.com/account/tokens
# VERCEL_TOKEN=
# VERCEL_PROJECT_ID=
# VERCEL_TEAM_ID=

# Ko-fi tip jar (public URL is KO_FI_URL in src/lib/config/site.ts)
# API key — server-side only (Vercel), NOT NEXT_PUBLIC_. For future admin sync / webhooks.
# KO_FI_API_KEY=KF_API_...

# Stripe — publishable key is only used client-side by the Payment Element
# (server calls use STRIPE_SECRET_KEY inside Supabase Edge secrets, NOT here).
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# AI assistant (/admin/ai, /admin/seo AI studio, /admin/konfigurator chat)
# Cascade order: GPT-OSS-120B → DeepSeek → Gemini. First one with a key wins,
# next is used as failover. All server-side only, never NEXT_PUBLIC_.
#
# GPT-OSS-120B (OpenAI-compatible endpoint — Groq / Cerebras / OpenRouter /
# fal.ai / self-host all work). Defaults: Groq at api.groq.com/openai/v1 and
# model openai/gpt-oss-120b. Override if you host elsewhere.
# GPT_OSS_API_KEY=
# GPT_OSS_BASE_URL=https://api.groq.com/openai/v1
# GPT_OSS_MODEL=openai/gpt-oss-120b
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-v4-pro
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# Email (Supabase Edge Function secrets — NOT Vercel for sending)
# See docs/email-setup.md and docs/security.md
# RESEND_API_KEY=          → resend.com API key (xkeysib- style via dashboard)
# BREVO_API_KEY=           → brevo.com REST API key (xkeysib-), NOT xsmtpsib- SMTP key
# RESEND_FROM_EMAIL=dario.admin@protosweb.eu
# CONTACT_EMAIL=dario.admin@protosweb.eu

# Zoho IMAP — admin inbox (/admin/inbox), NOT for public site
# Enable IMAP Access in Zoho for dario.admin@protosweb.eu
# ZOHO_IMAP_USER=dario.admin@protosweb.eu
# ZOHO_IMAP_PASSWORD=
# ZOHO_IMAP_HOST=imappro.zoho.eu
# ZOHO_IMAP_PORT=993

# Gmail studio IMAP — protoswebmark23@gmail.com (Google App Password required)
# GMAIL_STUDIO_IMAP_USER=protoswebmark23@gmail.com
# GMAIL_STUDIO_IMAP_PASSWORD=
# GMAIL_STUDIO_IMAP_HOST=imap.gmail.com
# GMAIL_STUDIO_IMAP_PORT=993

# Martina Zoho IMAP — when martina.admin@protosweb.eu is live
# MARTINA_IMAP_USER=martina.admin@protosweb.eu
# MARTINA_IMAP_PASSWORD=
# MARTINA_IMAP_HOST=imappro.zoho.eu
# MARTINA_IMAP_PORT=993

# Stripe — Supabase Edge secrets (NOT Vercel)
# Setup: docs/stripe-donations.md
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# SITE_URL=https://www.protosweb.eu

# 3D Configurator (/admin/konfigurator) — optional
# Sketchfab API token (per-user token from sketchfab.com/settings/password)
# Only required for the Sketchfab tab; Poly.Pizza works without a key.
# SKETCHFAB_API_TOKEN=
# POLY_PIZZA_API_KEY=          → optional, raises rate limits above ~30 req/min

# Admin API keys vault (/admin/kljucevi)
# AES-256-GCM master key — base64-encoded 32 bytes. Generate ONCE:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Set the SAME value in Vercel Production / Preview / Development.
# Losing this value = all vault entries become unreadable. Back it up.
# ADMIN_KEYS_ENCRYPTION_KEY=
