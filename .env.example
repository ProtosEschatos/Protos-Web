# Supabase — sole backend; keys from Dashboard → Settings → API (project laqnnzavwbojntfiqmxj)
# Prefer publishable key; legacy JWT anon key still supported as fallback.
NEXT_PUBLIC_SUPABASE_URL=https://laqnnzavwbojntfiqmxj.supabase.co
SUPABASE_URL=https://laqnnzavwbojntfiqmxj.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Site (see also src/lib/site.ts — single source of truth)
NEXT_PUBLIC_SITE_URL=https://protosweb.eu

# Analytics — GA4 (consent-gated; loads only after cookie opt-in)
# Defaults to G-HR9HK4SR7Q in code; set here to override or leave empty to use default.
NEXT_PUBLIC_GA_ID=G-HR9HK4SR7Q

# Alternative analytics (optional; can run alongside GA if both are set)
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=protosweb.eu

# Google Search Console — HTML meta verification (defaults to code value in
# src/lib/config/site.ts; set here only to override without redeploying code)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Private admin panel (/admin) — set a strong password; only you see the nav link after login
ADMIN_SECRET=

# Agent memory (/admin/memory) — GitHub only (ProtosEschatos/Protos-Agent; private → GITHUB_TOKEN on Vercel)
# AGENT_MEMORY_REPO=ProtosEschatos/Protos-Agent
# AGENT_MEMORY_BRANCH=main
# GITHUB_TOKEN=

# Error monitoring (optional) — /admin shows this as configured once set
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_DSN=

# Live service status on /admin ("Živi status servisa") — optional,
# each card shows "Nije podešeno" until its variable(s) are set.
# Cloudflare: dash.cloudflare.com → My Profile → API Tokens → read-only Zone token
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ZONE_ID=
# Sentry: sentry.io → Settings → Auth Tokens (needs project:read scope)
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG_SLUG=
# SENTRY_PROJECT_SLUG=

# AI assistant (/admin/ai) — server-side only, never NEXT_PUBLIC_
# DEEPSEEK_API_KEY=
# GEMINI_API_KEY=

# Email, Stripe, keep-alive — Supabase Edge secrets ONLY (see docs/security.md).
# Do NOT duplicate these on Vercel:
# RESEND_API_KEY, BREVO_API_KEY, STRIPE_*, KEEP_ALIVE_SECRET, CONTACT_EMAIL, RESEND_FROM_EMAIL, SITE_URL

# Zoho IMAP — admin inbox (/admin/inbox), NOT for public site
# Enable IMAP Access in Zoho for dario.admin@protosweb.eu
# ZOHO_IMAP_USER=dario.admin@protosweb.eu
# ZOHO_IMAP_PASSWORD=
# ZOHO_IMAP_HOST=imappro.zoho.eu
# ZOHO_IMAP_PORT=993

# Stripe — Supabase Edge secrets only (NOT Vercel). See docs/stripe-donations.md
