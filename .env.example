# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://laqnnzavwbojntfiqmxj.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Site (see also src/lib/site.ts — single source of truth)
NEXT_PUBLIC_SITE_URL=https://www.protosweb.eu

# Analytics — GA4 (consent-gated; loads only after cookie opt-in)
# Defaults to G-HR9HK4SR7Q in code; set here to override or leave empty to use default.
NEXT_PUBLIC_GA_ID=G-HR9HK4SR7Q

# Alternative analytics (optional; can run alongside GA if both are set)
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=protosweb.eu

# Email (Supabase Edge Function secrets — set in Supabase Dashboard, not Vercel)
# RESEND_API_KEY=          → resend.com API key (domain protosweb.eu must be verified)
# RESEND_FROM_EMAIL=dario.admin@protosweb.eu
# CONTACT_EMAIL=dario.admin@protosweb.eu
