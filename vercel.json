{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "redirects": [
    { "source": "/hr", "destination": "/", "permanent": true },
    { "source": "/hr/:path*", "destination": "/:path*", "permanent": true }
  ]
}
